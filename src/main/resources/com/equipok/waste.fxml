<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="TOP_CENTER" spacing="15.0" stylesheets="@styles.css" xmlns="http://javafx.com/javafx/19" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.equipok.WasteController">
   <children>
      <Label text="Registro de residuos y Gestión de informes">
         <font>
            <Font name="System Bold" size="20.0" />
         </font>
         <VBox.margin>
            <Insets top="10.0" />
         </VBox.margin>
      </Label>
      
      <GridPane hgap="15.0" vgap="10.0">
         <children>
            <Label text="Selecciona un producto: " GridPane.columnIndex="0" GridPane.rowIndex="0">
               <font><Font size="13.0" /></font>
            </Label>
            <ComboBox fx:id="cbProducts" prefWidth="250.0" promptText="Escoge un producto" GridPane.columnIndex="1" GridPane.rowIndex="0" />
            
            <Label text="Cantidad:" GridPane.columnIndex="0" GridPane.rowIndex="1">
               <font><Font size="13.0" /></font>
            </Label>
            <TextField fx:id="txtQuantity" prefWidth="250.0" promptText="Ingresa una cantidad entera" GridPane.columnIndex="1" GridPane.rowIndex="1" />
            
            <Label text="Razón/Motivo: " GridPane.columnIndex="0" GridPane.rowIndex="2">
               <font><Font size="13.0" /></font>
            </Label>
            <TextArea fx:id="txtReason" prefHeight="70.0" prefWidth="250.0" promptText="Escribe la razón" wrapText="true" GridPane.columnIndex="1" GridPane.rowIndex="2" />
         </children>
         <padding>
            <Insets left="20.0" right="20.0" />
         </padding>
      </GridPane>
      
      <HBox alignment="CENTER" spacing="30.0">
         <children>
            <Button mnemonicParsing="false" onAction="#saveRecord" prefWidth="100.0" styleClass="button-save" text="Guardar" />
            <Button mnemonicParsing="false" onAction="#cancelOperation" prefWidth="100.0" styleClass="button-cancel" text="Cancelar" />
         </children>
      </HBox>
      
      <VBox spacing="5.0" VBox.vgrow="ALWAYS">
         <children>
            <Label text="Informe sobre el historial de mermas">
               <font>
                  <Font name="System Bold" size="14.0" />
               </font>
            </Label>
            <TableView fx:id="tblWastes" prefHeight="200.0" prefWidth="500.0">
              <columns>
                <TableColumn fx:id="colId" prefWidth="60.0" text="ID" />
                <TableColumn fx:id="colProductId" prefWidth="90.0" text="ID del producto" />
                <TableColumn fx:id="colQuantity" prefWidth="85.0" text="Cantidad" />
                <TableColumn fx:id="colReason" prefWidth="140.0" text="Razón" />
                <TableColumn fx:id="colDate" prefWidth="125.0" text="Fecha de registro" />
              </columns>
            </TableView>
         </children>
         <padding>
            <Insets left="20.0" right="20.0" top="10.0" />
         </padding>
      </VBox>
   </children>
   <padding>
      <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
   </padding>
</VBox>
<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="600.0" prefWidth="850.0" stylesheets="@styles.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.equipok.InsumoController">
   <children>
      <VBox spacing="20.0" AnchorPane.bottomAnchor="20.0" AnchorPane.leftAnchor="20.0" AnchorPane.rightAnchor="20.0" AnchorPane.topAnchor="20.0">
         <children>
            <HBox alignment="CENTER_LEFT" spacing="20.0">
               <children>
                  <Label text="Control de Inventario - Insumos">
                     <font>
                        <Font name="Tw Cen MT Bold" size="26.0" />
                     </font>
                  </Label>
               </children>
            </HBox>

            <HBox spacing="25.0" VBox.vgrow="ALWAYS">
               <children>
                  
                  <VBox prefWidth="300.0" spacing="20.0" style="-fx-border-color: #cccccc; -fx-border-radius: 5; -fx-padding: 20;">
                     <children>
                        <Label text="Datos del Insumo">
                           <font>
                              <Font name="Tw Cen MT Bold" size="16.0" />
                           </font>
                        </Label>
                        
                        <VBox spacing="15.0">
                           <children>
                              <VBox spacing="5.0">
                                 <children>
                                    <Label text="Nombre:">
                                       <font>
                                          <Font name="Tw Cen MT" size="14.0" />
                                       </font>
                                    </Label>
                                    <TextField fx:id="txtNombre" promptText="Ej. Tomate, Leche" style="-fx-font-family: 'Tw Cen MT'; -fx-font-size: 14px;" />
                                 </children>
                              </VBox>
                              <VBox spacing="5.0">
                                 <children>
                                    <Label text="Cantidad a Ingresar:">
                                       <font>
                                          <Font name="Tw Cen MT" size="14.0" />
                                       </font>
                                    </Label>
                                    <TextField fx:id="txtCantidad" promptText="Ej. 10.5" style="-fx-font-family: 'Tw Cen MT'; -fx-font-size: 14px;" />
                                 </children>
                              </VBox>
                              <VBox spacing="5.0">
                                 <children>
                                    <Label text="Unidad de Medida:">
                                       <font>
                                          <Font name="Tw Cen MT" size="14.0" />
                                       </font>
                                    </Label>
                                    <ComboBox fx:id="cmbUnidad" maxWidth="1.7976931348623157E308" promptText="Seleccione unidad..." style="-fx-font-family: 'Tw Cen MT'; -fx-font-size: 14px;" />
                                 </children>
                              </VBox>
                              <VBox spacing="5.0">
                                 <children>
                                    <Label text="Stock Mínimo Alerta:">
                                       <font>
                                          <Font name="Tw Cen MT" size="14.0" />
                                       </font>
                                    </Label>
                                    <TextField fx:id="txtStockMinimo" promptText="Ej. 2.0" style="-fx-font-family: 'Tw Cen MT'; -fx-font-size: 14px;" />
                                 </children>
                              </VBox>
                           </children>
                        </VBox>
                        
                        <VBox alignment="CENTER" spacing="10.0">
                           <children>
                              <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleGuardarOIngresarInsumo" styleClass="button-success" text="Guardar / Añadir Stock">
                                 <font>
                                    <Font name="Tw Cen MT Bold" size="14.0" />
                                 </font>
                              </Button>
                              <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleEliminarInsumo" styleClass="button-danger" text="Eliminar Insumo">
                                 <font>
                                    <Font name="Tw Cen MT Bold" size="14.0" />
                                 </font>
                              </Button>
                           </children>
                           <VBox.margin>
                              <Insets top="10.0" />
                           </VBox.margin>
                        </VBox>
                     </children>
                  </VBox>
                  
                  <TableView fx:id="tablaInsumos" style="-fx-font-family: 'Tw Cen MT'; -fx-font-size: 14px;" HBox.hgrow="ALWAYS">
                    <columns>
                      <TableColumn fx:id="colId" prefWidth="55.0" text="ID" />
                      <TableColumn fx:id="colNombre" prefWidth="190.0" text="Nombre Insumo" />
                      <TableColumn fx:id="colCantidad" prefWidth="110.0" text="Stock Actual" />
                        <TableColumn fx:id="colUnidad" prefWidth="100.0" text="Unidad" />
                        <TableColumn fx:id="colStockMinimo" prefWidth="120.0" text="Stock Mínimo" />
                    </columns>
                     <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                     </columnResizePolicy>
                  </TableView>
               </children>
            </HBox>
            
            <HBox alignment="CENTER_RIGHT">
               <children>
                  <Button mnemonicParsing="false" onAction="#regresarAlMenu" prefWidth="150.0" text="Regresar al Menú">
                     <font>
                        <Font name="Tw Cen MT" size="14.0" />
                     </font>
                  </Button>
               </children>
            </HBox>
         </children>
      </VBox>
   </children>
</AnchorPane>
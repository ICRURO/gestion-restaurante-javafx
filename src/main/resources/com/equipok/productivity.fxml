<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="TOP_CENTER" prefHeight="450.0" prefWidth="700.0" spacing="15.0" style="-fx-background-color: #f8fafc; -fx-padding: 20px;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.equipok.ProductivityController">
   <children>
      
      <HBox alignment="CENTER_LEFT" prefWidth="660.0">
         <children>
            <VBox HBox.hgrow="ALWAYS">
               <children>
                  <Label text="Waiter Productivity Metrics" textFill="#1e293b">
                     <font>
                        <Font name="System Bold" size="24.0" />
                     </font>
                  </Label>
                  <Label text="Real-time report tracking total completed orders processed per waiter." textFill="#64748b" style="-fx-font-size: 12px;" />
               </children>
            </VBox>
            <Button mnemonicParsing="false" onAction="#handleRefreshReport" style="-fx-background-color: #3b82f6; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 12px; -fx-padding: 8px 12px;" text="🔄 Refresh Data" />
         </children>
      </HBox>
      
      <TableView fx:id="tableProductivity" prefHeight="300.0" prefWidth="660.0" style="-fx-font-size: 13px;" VBox.vgrow="ALWAYS">
        <columns>
          <TableColumn fx:id="colWaiterId" maxWidth="100.0" minWidth="60.0" prefWidth="80.0" text="Waiter ID" />
          <TableColumn fx:id="colWaiterName" prefWidth="380.0" text="Waiter Name" />
          <TableColumn fx:id="colTotalOrders" maxWidth="200.0" minWidth="120.0" prefWidth="180.0" text="Total Orders Processed" />
        </columns>
         <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
         </columnResizePolicy>
      </TableView>
      
      <HBox alignment="CENTER_LEFT" prefWidth="660.0">
         <children>
            <Button mnemonicParsing="false" onAction="#switchToPrimary" style="-fx-background-color: #64748b; -fx-text-fill: white; -fx-font-size: 12px; -fx-padding: 8px 16px;" text="← Return to Dashboard" />
         </children>
      </HBox>
      
   </children>
</VBox>
<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import java.lang.String?>
<?import javafx.collections.FXCollections?>

<AnchorPane prefHeight="600.0" prefWidth="900.0" styleClass="main-container" stylesheets="@styles.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.equipok.PersonalController">
   <children>
      <VBox alignment="TOP_CENTER" layoutX="30.0" layoutY="20.0" spacing="20.0" AnchorPane.leftAnchor="30.0" AnchorPane.rightAnchor="30.0" AnchorPane.topAnchor="20.0">
         <children>
            <Label styleClass="header-label" text="Gestión de Personal">
               <font>
                  <Font name="System Bold" size="28.0" />
               </font>
            </Label>
            
            <HBox spacing="30.0" VBox.vgrow="ALWAYS">
               <children>
                  <VBox prefWidth="300.0" spacing="15.0" styleClass="form-container">
                     <children>
                        <Label text="Nombre del Empleado" />
                        <TextField fx:id="txtNombre" promptText="Ej. Alan Estrada" styleClass="custom-textfield" />
                        
                        <Label text="Puesto" />
                        <TextField fx:id="txtPuesto" promptText="Ej. Mesero" styleClass="custom-textfield" />
                        
                        <Label text="Teléfono" />
                        <TextField fx:id="txtTelefono" promptText="2281234567" styleClass="custom-textfield" />
                        
                        <Label text="Turno" />
                        <ComboBox fx:id="cbTurno" prefWidth="300.0" promptText="Seleccione turno" styleClass="custom-combobox">
                           <items>
                              <FXCollections fx:factory="observableArrayList">
                                 <String fx:value="Matutino" />
                                 <String fx:value="Vespertino" />
                                 <String fx:value="Nocturno" />
                              </FXCollections>
                           </items>
                        </ComboBox>
                        
                        <HBox spacing="10.0" alignment="CENTER">
                           <children>
                              <Button mnemonicParsing="false" onAction="#handleGuardarEmpleado" prefWidth="120.0" styleClass="save-button" text="Guardar" />
                              <Button mnemonicParsing="false" onAction="#handleEliminarEmpleado" prefWidth="120.0" styleClass="delete-button" text="Eliminar" />
                           </children>
                        </HBox>
                        
                        <Button mnemonicParsing="false" onAction="#switchToPrimary" styleClass="back-button" text="Regresar al Menú" />
                     </children>
                  </VBox>
                  
                  <VBox HBox.hgrow="ALWAYS">
                     <children>
                        <TableView fx:id="tableEmpleados" prefHeight="450.0" styleClass="custom-table">
                          <columns>
                           <TableColumn fx:id="colId" text="ID" />
                           <TableColumn fx:id="colNombre" text="Nombre" />
                           <TableColumn fx:id="colPuesto" text="Puesto" />
                           <TableColumn fx:id="colTurno" text="Turno" />
                          </columns>
                           <columnResizePolicy>
                              <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                           </columnResizePolicy>
                        </TableView>
                     </children>
                  </VBox>
               </children>
            </HBox>
         </children>
      </VBox>
   </children>
</AnchorPane>
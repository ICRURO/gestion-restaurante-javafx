<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import java.lang.String?>
<?import javafx.collections.FXCollections?>

<AnchorPane prefHeight="600.0" prefWidth="900.0" style="-fx-background-color: #f8fafc;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.equipok.PersonalController">
   <children>
      <VBox alignment="TOP_CENTER" layoutX="30.0" layoutY="20.0" spacing="20.0" AnchorPane.bottomAnchor="20.0" AnchorPane.leftAnchor="30.0" AnchorPane.rightAnchor="30.0" AnchorPane.topAnchor="20.0">
         <children>
            
            <Label text="Personnel Management - Waiters Directory" textFill="#1e293b">
               <font>
                  <Font name="System Bold" size="26.0" />
               </font>
            </Label>
            
            <HBox spacing="30.0" VBox.vgrow="ALWAYS">
               <children>
                  
                  <VBox prefWidth="320.0" spacing="15.0" style="-fx-background-color: #ffffff; -fx-padding: 20px; -fx-border-color: #e2e8f0; -fx-border-radius: 8px; -fx-background-radius: 8px;">
                     <children>
                        <Label text="Waiter Name:" textFill="#475569">
                           <font>
                              <Font name="System Bold" size="12.0" />
                           </font>
                        </Label>
                        <TextField fx:id="txtNombre" promptText="e.g. Alan Estrada" style="-fx-font-size: 12px; -fx-padding: 6px;" />
                        
                        <Label text="Phone Number:" textFill="#475569">
                           <font>
                              <Font name="System Bold" size="12.0" />
                           </font>
                        </Label>
                        <TextField fx:id="txtTelefono" promptText="e.g. 2281234567" style="-fx-font-size: 12px; -fx-padding: 6px;" />
                        
                        <Label text="System Status:" textFill="#475569">
                           <font>
                              <Font name="System Bold" size="12.0" />
                           </font>
                        </Label>
                        <ComboBox fx:id="cmbEstado" prefWidth="320.0" promptText="Select system status" style="-fx-font-size: 12px;" />
                        
                        <VBox spacing="8.0" style="-fx-padding: 10px 0px 0px 0px;">
                           <children>
                              <HBox alignment="CENTER" spacing="12.0">
                                 <children>
                                    <Button mnemonicParsing="false" onAction="#handleGuardarEmpleado" prefWidth="130.0" style="-fx-background-color: #22c55e; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 12px; -fx-padding: 8px;" text="Save / Update" />
                                    
                                    <Button mnemonicParsing="false" onAction="#handleEliminarEmpleado" prefWidth="130.0" style="-fx-background-color: #f59e0b; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 12px; -fx-padding: 8px;" text="Disable Status" />
                                 </children>
                              </HBox>
                              
                              <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleBorrarWaiterPermanente" style="-fx-background-color: #ef4444; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 12px; -fx-padding: 8px;" text="Delete Permanently from DB" />
                              
                              <Separator prefWidth="200.0" style="-fx-padding: 5px 0px;" />
                              
                              <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#switchToPrimary" style="-fx-background-color: #64748b; -fx-text-fill: white; -fx-font-size: 12px; -fx-padding: 7px;" text="Return to Main Menu" />
                           </children>
                        </VBox>
                     </children>
                  </VBox>
                  
                  <VBox HBox.hgrow="ALWAYS">
                     <children>
                        <TableView fx:id="tableEmpleados" prefHeight="450.0" style="-fx-font-size: 12px;" VBox.vgrow="ALWAYS">
                          <columns>
                            <TableColumn fx:id="colId" maxWidth="70.0" minWidth="50.0" prefWidth="60.0" text="ID" />
                            <TableColumn fx:id="colNombre" prefWidth="220.0" text="Name" />
                            <TableColumn fx:id="colTelefono" prefWidth="140.0" text="Phone" />
                            <TableColumn fx:id="colEstado" prefWidth="110.0" text="Status" />
                          </columns>
                           <columnResizePolicy>
                              <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                           </columnResizePolicy>
                        </TableView>
                     </children>
                  </VBox>
                  
               </children>
            </HBox>
         </children>
      </VBox>
   </children>
</AnchorPane>
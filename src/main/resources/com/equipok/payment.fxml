<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.text.Font?>

<StackPane xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.equipok.PaymentController">
   <children>
      <Pane prefHeight="600.0" prefWidth="900.0" style="-fx-background-color: #F8FAFC;">
         <children>
            <Label layoutX="47.0" layoutY="40.0" styleClass="header-title" stylesheets="@styles.css" text="Liquidar cuenta">
               <font>
                  <Font name="System Bold" size="35.0" />
               </font>
            </Label>
            <Pane layoutX="47.0" layoutY="88.0" prefHeight="462.0" prefWidth="400.0" styleClass="card-panel" stylesheets="@styles.css">
               <children>
                  <TableView fx:id="productsTable" layoutY="54.0" prefHeight="227.0" prefWidth="400.0" stylesheets="@styles.css">
                    <columns>
                      <TableColumn fx:id="colProductName" prefWidth="275.0" text="Platillo" />
                      <TableColumn fx:id="colProductPrice" prefWidth="123.0" text="Precio" />
                    </columns>
                  </TableView>
                  <Label layoutX="21.0" layoutY="23.0" styleClass="label-main" stylesheets="@styles.css" text="Resumen de consumo" />
                  <CheckBox fx:id="chkAddDiscount" layoutX="21.0" layoutY="302.0" mnemonicParsing="false" styleClass="check-circular" stylesheets="@styles.css" text="¿Aplicar Cupón?" />
                  <TextField fx:id="txtDiscount" layoutX="157.0" layoutY="291.0" prefHeight="42.0" prefWidth="220.0" styleClass="modern-text-field" stylesheets="@styles.css" />
                  <CheckBox fx:id="chkAddTip" layoutX="19.0" layoutY="352.0" mnemonicParsing="false" styleClass="check-circular" stylesheets="@styles.css" text="¿Añadir propina?" />
                  <TextField fx:id="txtTip" layoutX="157.0" layoutY="341.0" prefHeight="42.0" prefWidth="220.0" styleClass="modern-text-field" stylesheets="@styles.css" />
                  <Separator layoutX="23.0" layoutY="392.0" prefHeight="3.0" prefWidth="354.0" />
                  <Label layoutX="23.0" layoutY="413.0" styleClass="label-main" stylesheets="@styles.css" text="Total a pagar: ">
                     <font>
                        <Font name="System Bold" size="12.0" />
                     </font>
                  </Label>
                  <Label fx:id="lblTotal" layoutX="133.0" layoutY="413.0" styleClass="label-main" stylesheets="@styles.css" />
               </children>
            </Pane>
            <Pane layoutX="498.0" layoutY="88.0" prefHeight="361.0" prefWidth="360.0" styleClass="card-panel" stylesheets="@styles.css">
               <children>
                  <Label layoutX="26.0" layoutY="22.0" styleClass="label-main" stylesheets="@styles.css" text="Selecciona método de pago" />
                  
                                    <ComboBox fx:id="cbMethod" layoutX="26.0" layoutY="50.0" prefHeight="37.0" prefWidth="308.0" stylesheets="@styles.css" />
                  <Label layoutX="26.0" layoutY="129.0" styleClass="label-sub" stylesheets="@styles.css" text="Monto recibido:" />
                  <TextField fx:id="txtReceived" layoutX="26.0" layoutY="159.0" prefHeight="42.0" prefWidth="308.0" styleClass="modern-text-field" stylesheets="@styles.css" />
                  <Separator layoutX="26.0" layoutY="106.0" prefHeight="3.0" prefWidth="308.0" />
                  <Label layoutX="26.0" layoutY="222.0" styleClass="label-main" stylesheets="@styles.css" text="Cambio:">
                     <font>
                        <Font size="44.0" />
                     </font>
                  </Label>
                  <Button fx:id="btnPay" layoutX="139.0" layoutY="304.0" mnemonicParsing="false" onAction="#handleConfirm" styleClass="btn-primary" stylesheets="@styles.css" text="Pagar" />
                  <Label fx:id="lblChange" layoutX="92.0" layoutY="223.0" styleClass="label-main" stylesheets="@styles.css" />
               </children>
            </Pane>
            <Pane fx:id="barraSuperior" prefHeight="40.0" prefWidth="900.0" />
            <Pane layoutX="498.0" layoutY="475.0" prefHeight="75.0" prefWidth="354.0" styleClass="card-panel" stylesheets="@styles.css">
               <children>
                  <Button layoutX="14.0" layoutY="17.0" mnemonicParsing="false" onAction="#handleCancel" styleClass="btn-secondary" stylesheets="@styles.css" text="Cancelar" />
               </children>
            </Pane>
         </children>
      </Pane>
   </children>
</StackPane>

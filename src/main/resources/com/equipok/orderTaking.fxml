<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.Pane?>

<Pane styleClass="sub-pane" stylesheets="@styles.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.equipok.OrderTakingController">
   <children>
      <Pane layoutX="40.0" layoutY="599.0" prefHeight="69.0" prefWidth="200.0" styleClass="card-horizontal-pane" stylesheets="@styles.css">
         <children>
              <Button layoutX="14.0" layoutY="15.0" onAction="#handleCancel" styleClass="btn-secondary" text="Regresar" />
         </children>
      </Pane>
      <Pane layoutX="586.0" layoutY="26.0" prefHeight="550.0" prefWidth="354.0" styleClass="card-panel">
         <children>
              <ComboBox fx:id="waiterComboBox" layoutX="183.0" layoutY="48.0" promptText="Seleccionar mesero" />
              <ComboBox fx:id="tableComboBox" layoutX="14.0" layoutY="48.0" promptText="Seleccionar mesa" />
              <Label layoutX="15.0" layoutY="28.0" styleClass="label-sub" text="Mesa:" />
              
              <Label layoutX="183.0" layoutY="28.0" styleClass="label-sub" text="Mesero:" />
            <Separator layoutX="16.0" layoutY="104.0" prefHeight="5.0" prefWidth="323.0" />
            <ListView fx:id="cartListView" layoutX="14.0" layoutY="128.0" prefHeight="340.0" prefWidth="323.0">
               <styleClass>
                  <String fx:value="card-panel" />
                  <String fx:value="table-view" />
               </styleClass>
            </ListView>
              <Button layoutX="89.0" layoutY="488.0" onAction="#handleConfirmOrder" styleClass="btn-ingresar" stylesheets="@styles.css" text="Confirmar Pedido" />
         </children>
      </Pane>
       
          <Label layoutX="40.0" layoutY="26.0" styleClass="header-title" text="Toma de Pedido" />
       
          <TableView fx:id="orderTable" layoutX="40.0" layoutY="82.0" prefHeight="400.0" prefWidth="500.0">
           <columns>
               <TableColumn fx:id="colItem" prefWidth="331.0" text="Producto" />
               <TableColumn fx:id="colPrice" prefWidth="163.0" text="Precio" />
           </columns>
       </TableView>
      <Button layoutX="452.0" layoutY="518.0" mnemonicParsing="false" onAction="#handleAddToCart" styleClass="btn-primary" text="Añadir" />
      <Button layoutX="320.0" layoutY="518.0" mnemonicParsing="false" onAction="#handleRemoveFromCart" styleClass="btn-primary" text="Eliminar" />
   </children>
</Pane>

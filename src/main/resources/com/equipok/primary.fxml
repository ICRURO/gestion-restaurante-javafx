<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>


<Pane prefHeight="600.0" prefWidth="900.0" style="-fx-background-color: #F8FAFC;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.equipok.PrimaryController">
   <children>
      <Button fx:id="btnAgregarProducto" layoutX="375.0" layoutY="325.0" mnemonicParsing="false" onAction="#abrirProductos" prefHeight="100.0" prefWidth="150.0" styleClass="action-card" stylesheets="@styles.css" text="Agregar producto" />
      <Button fx:id="btnPagarCuenta" layoutX="283.0" layoutY="177.0" mnemonicParsing="false" onAction="#switchToPayBill" prefHeight="100.0" prefWidth="150.0" styleClass="action-card" stylesheets="@styles.css" text="Pagar cuenta" />
      <Pane prefHeight="600.0" prefWidth="220.0" styleClass="sidebar" stylesheets="@styles.css">
         <children>
            <Label layoutX="22.0" layoutY="28.0" stylesheets="@styles.css" text="Sistema Gestión" textFill="WHITE">
               <font>
                  <Font name="Tw Cen MT Bold" size="20.0" />
               </font>
            </Label>
            <Label layoutX="22.0" layoutY="58.0" stylesheets="@styles.css" text="Restaurante" textFill="WHITE">
               <font>
                  <Font name="System Bold" size="20.0" />
               </font>
            </Label>
            <Label layoutY="109.0" prefHeight="40.0" prefWidth="220.0" styleClass="sidebar-label-active" stylesheets="@styles.css" text="Panel Principal" textFill="#ff5f6d" />
            <Label layoutX="3.0" layoutY="159.0" prefHeight="40.0" prefWidth="220.0" styleClass="sidebar-label" stylesheets="@styles.css" text="Inventario" textFill="#94a3b8" />
            <Label layoutX="3.0" layoutY="209.0" prefHeight="40.0" prefWidth="220.0" styleClass="sidebar-label" stylesheets="@styles.css" text="Mesas" textFill="#94a3b8" />
            <Label layoutX="3.0" layoutY="259.0" prefHeight="40.0" prefWidth="220.0" styleClass="sidebar-label" stylesheets="@styles.css" text="Personal" textFill="#94a3b8" />
            <Label layoutX="3.0" layoutY="300.0" prefHeight="40.0" prefWidth="220.0" styleClass="sidebar-label" stylesheets="@styles.css" text="Reportes" textFill="#94a3b8" />
         </children>
      </Pane>
      <Label layoutX="283.0" layoutY="55.0" text="Panel de control" textFill="#121212">
         <font>
            <Font name="System Bold" size="30.0" />
         </font>
      </Label>
      <Button fx:id="btnPedirOrden" layoutX="486.0" layoutY="177.0" mnemonicParsing="false" onAction="#switchToOrderTaking" prefHeight="100.0" prefWidth="150.0" styleClass="action-card" stylesheets="@styles.css" text="Toma de Pedido" />
      <Button fx:id="btnReporteVentas" layoutX="686.0" layoutY="177.0" mnemonicParsing="false" onAction="#switchToSalesReport" prefHeight="100.0" prefWidth="150.0" styleClass="action-card" stylesheets="@styles.css" text="Reporte de Ventas" />
      <Button fx:id="btnReservar" layoutX="592.0" layoutY="325.0" mnemonicParsing="false" onAction="#abrirReservas" prefHeight="100.0" prefWidth="150.0" styleClass="action-card" stylesheets="@styles.css" text="Reservar Mesa" />
      <Pane layoutX="838.0" layoutY="15.0" prefHeight="81.0" prefWidth="48.0">
         <children>
            <VBox prefHeight="82.0" prefWidth="48.0" styleClass="window-controls" stylesheets="@styles.css">
               <children>
                  <Button mnemonicParsing="false" stylesheets="@styles.css" text="  ">
                     <styleClass>
                        <String fx:value="mac-button" />
                        <String fx:value="mac-minimize" />
                     </styleClass>
                  </Button>
                  <Button mnemonicParsing="false" stylesheets="@styles.css" text="  ">
                     <styleClass>
                        <String fx:value="mac-button" />
                        <String fx:value="mac-close" />
                     </styleClass>
                  </Button>
               </children>
            </VBox>
         </children>
      </Pane>
   </children>
</Pane>

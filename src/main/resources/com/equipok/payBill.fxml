<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.text.Font?>

<Pane maxHeight="-Infinity" styleClass="sub-pane" stylesheets="@styles.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.equipok.PayBillController">
   <children>
      <Pane layoutX="40.0" layoutY="591.0" prefHeight="75.0" prefWidth="900.0" styleClass="card-horizontal-pane" stylesheets="@styles.css">
         <children>
            <Button fx:id="btnPay" layoutX="803.0" layoutY="17.0" mnemonicParsing="false" onAction="#handleProcessPayment" styleClass="btn-primary" stylesheets="@styles.css" text="Pagar" />
            <Button layoutX="14.0" layoutY="17.0" mnemonicParsing="false" onAction="#switchToPrimary" styleClass="btn-secondary" stylesheets="@styles.css" text="Regresar" />
         </children>
      </Pane>
      <Label layoutX="40.0" layoutY="37.0" styleClass="header-title" stylesheets="@styles.css" text="Pagar cuenta">
         <font>
            <Font name="System Bold" size="18.0" />
         </font>
      </Label>
      <TableView fx:id="billsTable" layoutX="40.0" layoutY="100.0" prefHeight="460.0" prefWidth="900.0" stylesheets="@styles.css">
        <columns>
          <TableColumn fx:id="colTableId" prefWidth="106.0" text="Mesa" />
          <TableColumn fx:id="colItems" prefWidth="675.0" text="Platillos" />
            <TableColumn fx:id="colTotal" minWidth="0.0" prefWidth="114.0" text="Total" />
        </columns>
      </TableView>
   </children>
</Pane>
